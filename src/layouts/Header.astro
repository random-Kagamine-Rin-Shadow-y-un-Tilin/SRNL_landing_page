---
import { Calendar } from "lucide-astro";
---
<header class="flex top-0 left-0 w-full z-50 justify-between bg-surface fixed px-6 py-3">
    <div id="logo" class="flex gap-2 items-center">
        <a href="#" class="bg-primary border-5 border-primary rounded-md"><Calendar class="text-primary-foreground"/></a>
        <a href="#" class="font-bold">CITAFY</a>
    </div>

    <nav class="hidden md:flex gap-6">
        <a href="#howWork" class="group relative inline-block transition duration-300">Cómo funciona <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-highlight transition-all duration-300 group-hover:w-full"></span></a>
        <a href="#forBussines" class="group relative inline-block transition duration-300">Negocios <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-highlight transition-all duration-300 group-hover:w-full"></span></a>
        <a href="#prices" class="group relative inline-block transition duration-300">Precios <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-highlight transition-all duration-300 group-hover:w-full"></span></a>
        <a href="#help" class="group relative inline-block transition duration-300">Ayuda <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-highlight transition-all duration-300 group-hover:w-full"></span></a>
        <a href="#" class="group relative inline-block transition duration-300">Empezar <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-highlight transition-all duration-300 group-hover:w-full"></span></a>
    </nav>
</header>