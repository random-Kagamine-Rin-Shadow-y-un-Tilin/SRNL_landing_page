---
import { Calendar } from "lucide-astro";
import { Icon } from "astro-icon/components";
---


<footer id="footer" class="bg-foreground text-secondary-text gap-4 flex flex-col">
    <div class="flex flex-col justify-between gap-4 p-8 md:flex-row">

        <div class="flex flex-col gap-3">
            <a href="#" class="flex gap-2 text-background">
                <Calendar class="p-1 bg-primary rounded-md"  size={30}/>
                <span class="font-medium">CITAFY</span>
            </a>

            <div class="flex flex-col">
                <p>Agenda citas en restaurantes, peluquerías,</p>
                <p>spas y más, sin llamadas ni esperas.</p>
            </div>

            <div class="flex gap-2 text-background">
                <a href="#"> 
                    <Icon name="proicons:instagram" class="p-1 bg-white/10 h-8 w-8 rounded-md" />
                </a>
                <a href="#"> 
                    <Icon name="proicons:tiktok" class="p-1 bg-white/10 h-8 w-8 rounded-md" />
                </a>
                <a href="#"> 
                    <Icon name="proicons:x-twitter" class="p-1 bg-white/10 h-8 w-8 rounded-md" />
                </a>
            </div>
        </div>

        <div class="flex flex-col gap-4">
            <span class="text-background font-medium">Producto</span>

            <div class="flex flex-col gap-1">
                <a href="#howWork">Cómo funciona</a>
                <a href="#forBussines">Para negocios</a>
                <a href="#prices">Precios</a>
                <a href="#help">Ayuda</a>
                <a href="#">Empezar</a>
            </div>
        </div>

        <div class="flex flex-col gap-4">
            <span class="text-background font-medium">Compañia</span>

            <div class="flex flex-col gap-1">
                <a href="#">Sobre nosotros</a>
                <a href="#">Blog</a>
                <a href="#">Trabaja con nosotros</a>
                <a href="#">Contacto</a>
            </div>
        </div>

        <div>
            <span class="text-background font-medium">Ayuda</span>

            <div class="flex flex-col gap-1">
                <a href="#help">Preguntas frecuentes</a>
                <a href="#">Terminos y condiciones</a>
                <a href="#">Aviso de privacidad</a>
                <a href="#">Soporte</a>
            </div>
        </div>

    </div>

    <div class="flex flex-col justify-between items-center border-t p-4 md:flex-row">
        <span>© 2026 Citafy. Todos los derechos reservados.</span>
        <div class="flex gap-1 items-center">
            <span>Hecho con</span>
            <Icon class="text-primary" name="proicons:heart" />
            <span>en México</span>
        </div>
    </div>
</footer>